      "cell_type": "markdown",
      "source": [
        "# Golden Ratio Approximation: 1/φ² to 1/3\n\n",
        "Demonstrates 1/φ² ≈ 0.382 → 1/3 with ε ≈ -0.145 correction."
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "import numpy as np\n\n",
        "phi = (1 + np.sqrt(5)) / 2\n",
        "one_over_phi_sq = 1 / phi**2\n",
        "epsilon = -0.145\n",
        "corrected = one_over_phi_sq * (1 + epsilon)\n\n",
        "print(f\"1/φ²: {one_over_phi_sq:.6f}\")\n",
        "print(f\"Corrected (ε = {epsilon}): {corrected:.6f}\")\n",
        "print(f\"Target 1/3: {1/3:.6f}\")\n",
        "print(f\"Error: {abs(corrected - 1/3) / (1/3) * 100:.4f}%\")"
      ]
    }
  ]
}
