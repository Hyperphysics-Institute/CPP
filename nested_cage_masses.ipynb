    "# Quark Generational Mass Hierarchy from Nested 600-Cell Cages\n",
    "\n",
    "CPP v8.0 — Mass ∝ ∫ S(r) γ(r) dV over successive polyhedral shells\n",
    "\n",
    "**New in this version**: Inner SSV adjustment for bare up quark ZBW orbit (stronger local stress reduces overlap → exact 2.2 MeV match)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from parameters_600cell import phi, k_curvature, n_events_default"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Shell radii scaling (approximate 600-cell nested subgraphs)\n",
    "shell_scaling = {\n",
    "    '1st (bare)': 1.0,\n",
    "    '2nd (tetra + icosa)': np.sqrt(phi),           # ~1.272\n",
    "    '3rd (tetra + icosa + dodeca + fullerene)': phi**2  # ~2.618\n",
    "}"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Mass ∝ ∫ S(r) γ(r) dV over cage volume (radial approximation)\n",
    "def cage_mass_integral(max_shell_factor=1.0, n_points=2000):\n",
    "    r = np.linspace(0.01, max_shell_factor, n_points)\n",
    "    dr = r[1] - r[0]\n",
    "    \n",
    "    S = 1.0 / r**4\n",
    "    gamma = 1 + k_curvature * S\n",
    "    integrand = gamma * S * r**2 * dr\n",
    "    \n",
    "    total = np.sum(integrand)\n",
    "    return total"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
