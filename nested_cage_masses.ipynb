   "source": [
    "# Quark Generational Mass Hierarchy from Nested 600-Cell Cages\n",
    "\n",
    "CPP v8.0 — Mass ∝ ∫ S(r) γ(r) dV over successive polyhedral shells"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from parameters_600cell import k_curvature, n_events_default, phi"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Shell radii scaling (approximate 600-cell nested subgraphs)\n",
    "shell_scaling = {\n",
    "    '1st (bare)': 1.0,\n",
    "    '2nd (tetra + icosa)': np.sqrt(phi),           # ~1.272\n",
    "    '3rd (tetra + icosa + dodeca + fullerene)': phi**2  # ~2.618\n",
    "}"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Mass ∝ ∫ S(r) γ(r) dV over cage volume (radial approximation)\n",
    "def cage_mass_integral(max_shell_factor=1.0, n_points=2000):\n",
    "    r = np.linspace(0.01, max_shell_factor, n_points)\n",
    "    dr = r[1] - r[0]\n",
    "    \n",
    "    S = 1.0 / r**4\n",
    "    gamma = 1 + k_curvature * S\n",
    "    integrand = gamma * S * r**2 * dr\n",
    "    \n",
    "    total = np.sum(integrand)\n",
    "    return total"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Base light quark mass anchor (up/down avg ~3–5 MeV)\n",
    "base_mass = 3.5  # MeV\n",
    "\n",
    "masses = {}\n",
    "for gen, factor in shell_scaling.items():\n",
    "    integral = cage_mass_integral(max_shell_factor=factor)\n",
    "    norm_integral = cage_mass_integral(max_shell_factor=1.0)\n",
    "    mass = base_mass * (integral / norm_integral)\n",
    "    masses[gen] = mass\n",
    "\n",
    "# Down uplift from extra hDP\n",
    "down_uplift = 2.2\n",
    "\n",
    "print(\"Quark Generational Masses:\")\n",
    "for gen, m in masses.items():\n",
    "    if \"1st\" in gen:\n",
    "        print(f\"{gen}\")\n",
    "        print(f\"  Up:   {m - down_uplift/2:.1f} MeV\")\n",
    "        print(f\"  Down: {m + down_uplift/2:.1f} MeV\")\n",
    "    else:\n",
    "        print(f\"{gen}: {m:.0f} MeV\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
