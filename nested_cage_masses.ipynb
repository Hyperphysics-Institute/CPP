"""
nested_cage_masses.ipynb
Quark generational mass hierarchy from nested 600-cell polyhedral cages
CPP v8.0 — Integrates SSV compression over successive shells
"""

import numpy as np
import matplotlib.pyplot as plt
from parameters_600cell import k_curvature, n_events_default

# Shell radii scaling (approximate 600-cell nested subgraphs)
# Bare → Tetra → Icosa → Dodeca → Fullerene-like
shell_scaling = {
    '1st (bare)': 1.0,
    '2nd (tetra + icosa)': 1.0 * np.sqrt(phi),           # ~1.272
    '3rd (tetra + icosa + dodeca + fullerene)': 1.0 * phi**2  # ~2.618
}

# Mass ∝ ∫ S(r) γ(r) dV over cage volume
# Use radial approximation
def cage_mass_integral(max_shell_factor=1.0, n_points=2000):
    r = np.linspace(0.01, max_shell_factor, n_points)
    dr = r[1] - r[0]
    
    S = 1.0 / r**4
    gamma = 1 + k_curvature * S
    integrand = gamma * S * r**2 * dr  # Volume element
    
    total = np.sum(integrand)
    return total

# Base light quark mass (1st generation, calibrated to up/down avg ~3-5 MeV)
# Use known up/down as anchor
base_mass = 3.5  # MeV (average light quark)

masses = {}
for gen, factor in shell_scaling.items():
    integral = cage_mass_integral(max_shell_factor=factor)
    # Normalize to 1st gen = base_mass
    norm_integral = cage_mass_integral(max_shell_factor=1.0)
    mass = base_mass * (integral / norm_integral)
    masses[gen] = mass

# Down quark slight uplift from extra hDP (fixed +2 MeV in model)
down_uplift = 2.2  # Fits strange-like step

print("Quark Generational Masses (600-cell nested cages):")
for gen, m in masses.items():
    if "1st" in gen:
        print(f"{gen}")
        print(f"  Up:   {m - down_uplift/2:.1f} MeV")
        print(f"  Down: {m + down_uplift/2:.1f} MeV")
    else:
        print(f"{gen}: {m:.0f} MeV")

# Monte Carlo variation (phase/sea fluctuations)
def mc_cage_mass(gen_factor, n_events=n_events_default):
    integrals = []
    for _ in range(n_events):
        fluct = np.random.normal(1.0, 0.015)  # ±1.5% shell variation
        integrals.append(cage_mass_integral(max_shell_factor=gen_factor * fluct))
    norm = cage_mass_integral(1.0)
    masses = base_mass * np.array(integrals) / norm
    return np.mean(masses), np.std(masses)

print("\nEnsemble example — 3rd generation (top/bottom avg):")
mean_3rd, std_3rd = mc_cage_mass(shell_scaling['3rd (tetra + icosa + dodeca + fullerene)'])
print(f"Mean: {mean_3rd:.0f} ± {std_3rd:.0f} MeV (cf. top ~173 GeV, bottom ~4.2 GeV after flavor split)")

# Plot mass scaling
gens = list(shell_scaling.keys())
factors = list(shell_scaling.values())
integrals = [cage_mass_integral(f) for f in factors]
norm = integrals[0]
scaled = np.array(integrals) / norm

plt.figure(figsize=(8,5))
plt.plot(gens, base_mass * scaled, 'o-', markersize=10)
plt.yscale('log')
plt.ylabel('Mass (MeV, log scale)')
plt.title('Generational Mass Hierarchy from Nested Cages')
plt.grid(True, which='both')
plt.xticks(rotation=15)
plt.show()
