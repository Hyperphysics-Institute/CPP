"""
nucleon_NBT_bonding.ipynb
Nucleon Binding Tetra (NBT) primary bonding + stress-dependent chain insertion
CPP v8.0 — 600-cell lattice version
"""

import numpy as np
import matplotlib.pyplot as plt
from parameters_600cell import phase_probs, phase_choices, n_events_default

# NBT: Tetrahedral subgraph with two hybrid DPs (Type A +qCP/-eCP, Type B -qCP/+eCP)
# Primary bonding energy: Full charge + strong affinity at short range (unstressed)
def nbt_bonding_energy(stress_level=0.0, use_variation=False):
    """
    stress_level: 0.0 = compact (primary NBT affinity)
                  1.0 = fully stretched (max chain insertion)
    """
    # Base NBT affinity (strongest, integer charge + qCP rule bonus)
    base = 1.0  # Normalized units
    
    # Stress stretches edges → gaps for chain insertion
    # Central qDP first (strongest), then layers
    chains_inserted = stress_level**2  # Quadratic growth with stress
    
    # Layer contributions (weighted by strength: qDP > hDP ≈ eDP)
    qdp_contrib = min(chains_inserted, 1.0) * 1.2       # Central qDP strongest
    hdp_edp_contrib = max(0, chains_inserted - 1.0) * 0.8  # Subsequent layers
    
    total = base + qdp_contrib + hdp_edp_contrib
    
    if use_variation:
        total += np.random.normal(0, 0.02)  # Phase/sea fluctuation
    
    return total

# Proton (uud): 1 up bonds to negative NBT poles, 2 downs to positive
# Neutron (udd): opposite polarity bias
def nucleon_mass(proton=True, stress_level=0.0):
    base_nucleon = 938.0  # MeV anchor (avg from light quark cages)
    bonding = nbt_bonding_energy(stress_level)
    polarity = 0.15 if proton else -0.10
    return base_nucleon * (1 + polarity * 0.001 + (bonding - 1.0) * 0.01)

# Single values (unstressed nucleons)
proton_mass = nucleon_mass(proton=True)
neutron_mass = nucleon_mass(proton=False)
print(f"Unstressed NBT:")
print(f"Proton mass: {proton_mass:.1f} MeV")
print(f"Neutron mass: {neutron_mass:.1f} MeV")

# Stressed (high-energy probe)
stress_levels = np.linspace(0, 1.0, 10)
proton_stressed = [nucleon_mass(proton=True, stress_level=s) for s in stress_levels]
neutron_stressed = [nucleon_mass(proton=False, stress_level=s) for s in stress_levels]

plt.figure(figsize=(8,5))
plt.plot(stress_levels, proton_stressed, 'o-', label='Proton (uud)')
plt.plot(stress_levels, neutron_stressed, 's-', label='Neutron (udd)')
plt.xlabel('Stress level (normalized)')
plt.ylabel('Effective mass / binding energy (MeV)')
plt.title('NBT Primary Bonding + Stress-Dependent Chain Strengthening')
plt.legend()
plt.grid(True)
plt.show()

# Ensemble under typical stress (e.g., nuclear binding)
mean_proton, std_proton = np.mean([nucleon_mass(proton=True, stress_level=0.3, use_variation=True) 
                                   for _ in range(n_events_default)]), \
                         np.std([nucleon_mass(proton=True, stress_level=0.3, use_variation=True) 
                                 for _ in range(n_events_default)])

print(f"\nEnsemble (moderate stress): Proton {mean_proton:.1f} ± {std_proton:.1f} MeV")
